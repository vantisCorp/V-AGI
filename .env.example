# OMNI-AI Configuration
APP_NAME=OMNI-AI
APP_VERSION=0.1.0
ENVIRONMENT=development

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-32-bytes
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Database Connections
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Vector Database
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=omni-ai-vectors

# AI Model Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENAI_API_KEY=your-openai-api-key

# Agent Configuration
MAX_CONCURRENT_AGENTS=10
AGENT_TIMEOUT_SECONDS=300
TASK_QUEUE_MAX_SIZE=1000

# Security Configuration
MAX_LOGIN_ATTEMPTS=5
LOGIN_COOLDOWN_MINUTES=15
2FA_ENABLED=true
BIOMETRIC_AUTH_ENABLED=false

# Memory Configuration
WORKING_MEMORY_SIZE=1000
LONG_TERM_MEMORY_ENABLED=true
VECTOR_STORE_DIMENSION=1536

# Sandbox Configuration
SANDBOX_ENABLED=true
DOCKER_NETWORK=omni-ai-network
SANDBOX_TIMEOUT_SECONDS=600

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/omni-ai.log

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Simulation Configuration
OPENFOAM_ENABLED=true
FREECAD_ENABLED=true
MAX_SIMULATION_TIME_SECONDS=3600